# =========================================================================
# GLOBAL ENVIRONMENT SETTINGS
# =========================================================================
NODE_ENV=development
TZ=Asia/Ho_Chi_Minh

# =========================================================================
# BACKEND (API) CONFIGURATION
# =========================================================================
APP_NAME="Identify Voice API"
APP_VERSION="1.0.0"
BE_PORT=3000
BACKEND_URL="http://localhost:3000"

# Security & Auth
JWT_ACCESS_SECRET=your_super_secret_access_jwt_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_jwt_key_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
JWT_SECRET=your-super-secret-jwt-key-here
JWT_EXPIRES_IN=24h
BCRYPT_ROUNDS=12

# Storage & Uploads
UPLOAD_DEST=./uploads
MAX_FILE_SIZE=10485760
STORAGE_DRIVER=local
STORAGE_ROOT_DIR=./storage
STORAGE_PUBLIC_DIR_NAME=public
STORAGE_PRIVATE_DIR_NAME=private
STORAGE_TEMP_DIR_NAME=temp
ASSET_CDN_URL="http://localhost:3000/cdn"
ASSET_MAX_FILE_SIZE=10485760
ASSET_ALLOWED_MIME_TYPES=image/jpeg,image/png,image/gif,image/webp,image/svg+xml,video/mp4,video/quicktime,audio/mpeg,audio/wav,application/pdf

# =========================================================================
# DATABASE (POSTGRESQL) CONFIGURATION
# =========================================================================
DB_HOST=localhost
DB_PORT=5435
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=app
DB_SCHEMA=public

# Standardized DATABASE_URL
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}?schema=${DB_SCHEMA}

# Docker Database Config (Keep in sync with variables above)
POSTGRES_USER=${DB_USER}
POSTGRES_PASSWORD=${DB_PASSWORD}
POSTGRES_DB=${DB_NAME}
DEV_DB_PORT=5435
PROD_DB_PORT=5435

# =========================================================================
# CACHE (REDIS) CONFIGURATION
# =========================================================================
REDIS_HOST=localhost
REDIS_PORT=6380
REDIS_PASSWORD=redis_password_123
REDIS_DB_PORT=6380

# Standardized REDIS_URL
REDIS_URL=redis://${REDIS_PASSWORD}@${REDIS_HOST}:${REDIS_PORT}

# =========================================================================
# EMAIL (SMTP) CONFIGURATION
# =========================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="Your Base <no-reply@ecommerce.com>"
EMAIL_FROM="${APP_NAME} <${SMTP_USER}>"
EMAIL_TEMPLATES_PATH=src/module/email/templates

# =========================================================================
# THIRD-PARTY SERVICES & OAUTH
# =========================================================================

# Google OAuth
GOOGLE_CLIENT_ID="GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="GOOGLE_CLIENT_SECRET"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/v1/auth/google/callback"

# =========================================================================
# MONITORING & LOGGING
# =========================================================================
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
PROMETHEUS_ENABLED=false
METRICS_PORT=9090
HEALTH_ENDPOINTS_ENABLED=false

# =========================================================================
# NETWORK & CORS
# =========================================================================
CORS_ORIGINS="http://localhost:3001,http://localhost:3000,http://localhost:5173"
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100



# =========================================================================
# COOKIE
# =========================================================================
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_MAX_AGE=604800000
COOKIE_PATH=/

